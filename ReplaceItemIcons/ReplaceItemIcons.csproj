    <Import Project="$(MSBuildToolsPath)\Microsoft.CSharp.targets"/>

    <Target Name="PostBuild" AfterTargets="PostBuildEvent">
        <Copy SourceFiles="$(TargetPath)" DestinationFolder="$(GameDir)\BepInEx\plugins\ReplaceItemIcons\"/>
    </Target>
